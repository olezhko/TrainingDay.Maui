<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:model="clr-namespace:TrainingDay.Maui.ViewModels"
             x:Class="TrainingDay.Maui.Views.BlogItemPage"
             Title="{Binding Title}">
    <ContentPage.BindingContext>
        <model:BlogViewModel/>
    </ContentPage.BindingContext>
    <Grid RowDefinitions="*,auto">
        <WebView Source="{Binding WebViewDataText}" Grid.Row="0" />
        <Label Text="{Binding DateTime}" HorizontalOptions="End" TextColor="{StaticResource Gray300}" Grid.Row="1" />
    </Grid>
</ContentPage>